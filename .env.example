# Copy this to .env and fill in your values. Never commit .env.

# LLM
GROQ_API_KEY=

# MCP server (hosted on Render)
MCP_SERVER_URL=https://saksham-mcp-server.onrender.com/

# Email delivery gate
# Set to true ONLY in production. Non-production envs ignore this and stay draft-only.
CONFIRM_SEND=false

# Environment: development | staging | production
# confirm_send is forced false unless PULSE_ENV=production
PULSE_ENV=development

# Optional: override default SQLite path (default: data/pulse.db)
# DB_PATH=data/pulse.db
