{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocSection",
  "description": "Schema for the Google Docs batchUpdate request list produced by docs_tree.py (Phase 4).",
  "type": "array",
  "items": {
    "type": "object",
    "minProperties": 1,
    "maxProperties": 1,
    "anyOf": [
      { "required": ["insertText"] },
      { "required": ["updateParagraphStyle"] },
      { "required": ["updateTextStyle"] },
      { "required": ["insertTable"] }
    ]
  }
}
